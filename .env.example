# Default course for ./start.sh — must match the course you activated in Remotion (moduleContent.ts)
SLIDES_COURSE_ID=network-automation-program-networks

# GUI authentication (required for cloud deployment)
GUI_AUTH_USERNAME=admin
GUI_AUTH_PASSWORD=change-me-to-a-strong-password
GUI_SESSION_SECRET=

# Render tuning: reserve cores for GUI/OS/Gentle; cap max Remotion threads
REMOTION_CPU_RESERVE=1
REMOTION_CONCURRENCY=

# Show RunPod option in GUI render dropdowns (default: local-only render)
RENDER_RUNPOD_ENABLED=false

# Docker helper services (Gentle / MFA / optional Remotion Studio in Docker).
# The GUI and full course assets run on the HOST — see docker-compose.yml header.
#
# Host GUI (recommended local dev):
#   npm run gui
#   npm start
#
# Docker helpers:
#   docker compose pull
#   docker compose up -d
#   npm run mfa:download-models
#   docker compose --profile studio up -d --build remotion
#
# Production full platform in containers: docker-compose.prod.yml + SLIDES_IMAGE
GENTLE_URL=http://localhost:8765
GENTLE_HOST_PORT=8765
GENTLE_TIMEOUT_MS=600000

# Montreal Forced Aligner (best accuracy for TTS + script)
# auto = use local mfa if installed, else Docker (recommended on Windows)
MFA_USE_DOCKER=auto
MFA_DOCKER_IMAGE=mmcauliffe/montreal-forced-aligner:latest
# Dictionary and acoustic model must use the same name (matched phone set)
MFA_DICTIONARY=english_mfa
MFA_ACOUSTIC_MODEL=english_mfa
MFA_TIMEOUT_MS=900000
# One-time after pull: npm run mfa:download-models
# Remotion Studio preview (host npm start OR docker compose --profile studio)
REMOTION_STUDIO_URL=http://localhost:3000
REMOTION_HOST_PORT=3000

# Production image (docker-compose.prod.yml)
SLIDES_IMAGE=ghcr.io/f2ka07/ai-video-animation:latest

# API keys used by gui-server (copy from your local .env as needed)
OPENAI_API_KEY=
RUNPOD_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
RESEMBLE_API_KEY=
