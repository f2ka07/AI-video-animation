# LLM Provider Configuration
LLM_PROVIDER=groq
LLM_MODEL_PLANNER=llama-3.3-70b-versatile
LLM_MODEL_TOOL=llama-3.3-70b-versatile
LLM_MODEL_CRITIC=llama-3.1-8b-instant

# API Keys
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# NVIDIA NIM Configuration (optional)
NVIDIA_NIM_BASE_URL=
NVIDIA_NIM_API_KEY=

# Embeddings Configuration
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
VECTORSTORE_BACKEND=chromadb

# Database Configuration
DB_URL=sqlite:///./agent_state.db

# NeMo Guardrails (optional)
USE_NEMO_GUARDRAILS=false

# Monitoring
LOG_LEVEL=INFO
