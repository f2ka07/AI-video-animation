# Whisper Service Configuration
# Provider options: "local", "huggingface", "runpod", "whisperapi"
WHISPER_PROVIDER=local
WHISPER_MODEL=base.en
WHISPER_URL=http://whisper-svc:9000/transcribe
WHISPER_API_KEY=

# RunPod Configuration (required if WHISPER_PROVIDER=runpod)
# Set PUBLIC_URL to your RunPod pod's public endpoint (e.g., https://xxx-xxx-xxx.runpod.net)
# This allows RunPod Whisper API to access files served from the orchestrator
PUBLIC_URL=

# GPU Configuration (set empty string to force CPU mode)
CUDA_VISIBLE_DEVICES=

# Azure Speech Service Configuration (required only if AZURE_MODE=real)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# Service Modes: "real" or "stub"
# Set to "stub" for testing without real service credentials
AZURE_MODE=stub
TTS_MODE=stub

# Voice Style Configuration
DEFAULT_STYLE=instructor

# TTS Provider Configuration (required only if TTS_MODE=real)
TTS_PROVIDER=elevenlabs
TTS_API_KEY=your_tts_api_key_here
